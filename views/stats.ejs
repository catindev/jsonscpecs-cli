<%- include('_header', { title: (pipeline.description || pipeline.id) + ' — Статистика', isLibrary: pipeline.id.startsWith('library.'), icons }) %>

<a class="back-link" href="/pipelines/<%= encodeURIComponent(pipeline.id) %>">
  <svg viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  <%= pipeline.description || pipeline.id %>
</a>

<div class="hero">
  <span class="hero-icon"><%- pipeline.id.startsWith('library.') ? icons['big-pipline-library'] : icons['big-pipline'] %></span>
  <div class="hero-body">
    <h1 class="hero-title"><%= pipeline.description || pipeline.id %></h1>
    <div class="hero-sub"><strong>Сценарий:</strong> <%= pipeline.id %></div>
  </div>
</div>

<div class="tabs">
  <a class="tab-btn tab-btn--link" href="/pipelines/<%= encodeURIComponent(pipeline.id) %>">Структура</a>
  <button class="tab-btn tab-btn--active">Статистика</button>
  <a class="tab-btn tab-btn--link" href="/pipelines/<%= encodeURIComponent(pipeline.id) %>/doc">Документация</a>
  <a class="tab-btn tab-btn--link" href="/pipelines/<%= encodeURIComponent(pipeline.id) %>/playground">Проверить</a>
</div>

<% if (stats.warnings && stats.warnings.length) { %>
<div class="stats-warnings">
  <div class="stats-warnings-title">
    <svg viewBox="0 0 16 16" fill="none" width="16" height="16"><path d="M8 2L1 14h14L8 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 7v3M8 11.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    Предупреждения (<%= stats.warnings.length %>)
  </div>
  <ul class="stats-warnings-list">
    <% stats.warnings.forEach(function(w) { %>
    <li><%= w %></li>
    <% }) %>
  </ul>
</div>
<% } %>

<div class="stats-grid">

  <!-- Состав -->
  <div class="stats-card">
    <div class="stats-card-title">Состав сценария</div>
    <div class="stats-rows">
      <div class="stats-row">
        <span class="stats-label">Всего шагов в дереве</span>
        <span class="stats-value stats-value--main"><%= stats.totalSteps %></span>
      </div>
      <div class="stats-row">
        <span class="stats-label">правил (rule)</span>
        <span class="stats-value"><%= stats.rules %></span>
      </div>
      <div class="stats-row">
        <span class="stats-label">условий (condition)</span>
        <span class="stats-value"><%= stats.conditions %></span>
      </div>
      <div class="stats-row">
        <span class="stats-label">вложенных сценариев</span>
        <span class="stats-value"><%= stats.pipelines %></span>
      </div>
    </div>
  </div>

  <!-- Сложность -->
  <div class="stats-card">
    <div class="stats-card-title">Сложность</div>
    <div class="stats-rows">
      <div class="stats-row">
        <span class="stats-label">Максимальная глубина</span>
        <span class="stats-value stats-value--main <%= stats.maxDepth >= 5 ? 'stats-value--warn' : '' %>"><%= stats.maxDepth %></span>
      </div>
      <div class="stats-row">
        <span class="stats-label">Из библиотеки</span>
        <span class="stats-value <%= stats.libraryPct < 50 ? 'stats-value--warn' : 'stats-value--ok' %>"><%= stats.libraryPct %>%</span>
      </div>
      <div class="stats-row">
        <span class="stats-label">Библиотечных шагов</span>
        <span class="stats-value"><%= stats.librarySteps %></span>
      </div>
      <div class="stats-row">
        <span class="stats-label">Локальных шагов</span>
        <span class="stats-value"><%= stats.localSteps %></span>
      </div>
    </div>
  </div>

  <!-- Библиотека — прогрессбар -->
  <div class="stats-card stats-card--wide">
    <div class="stats-card-title">Переиспользование библиотеки</div>
    <div class="stats-bar-wrap">
      <div class="stats-bar">
        <div class="stats-bar-fill stats-bar-fill--lib" style="width:<%= stats.libraryPct %>%"></div>
        <div class="stats-bar-fill stats-bar-fill--local" style="width:<%= 100 - stats.libraryPct %>%"></div>
      </div>
      <div class="stats-bar-legend">
        <span class="stats-bar-dot stats-bar-dot--lib"></span> Библиотека <%= stats.libraryPct %>%
        &nbsp;&nbsp;
        <span class="stats-bar-dot stats-bar-dot--local"></span> Локальные <%= 100 - stats.libraryPct %>%
      </div>
    </div>
  </div>

  <!-- Дубли -->
  <% if (stats.duplicates && stats.duplicates.length) { %>
  <div class="stats-card stats-card--wide">
    <div class="stats-card-title">Правила встречающиеся более одного раза</div>
    <ul class="stats-dupes">
      <% stats.duplicates.forEach(function(d) { %>
      <li class="stats-dupe">
        <a href="/rules/<%= encodeURIComponent(d[0]) %>" class="stats-dupe-id"><%= d[0] %></a>
        <span class="stats-dupe-count"><%= d[1] %> раза</span>
      </li>
      <% }) %>
    </ul>
  </div>
  <% } else { %>
  <div class="stats-card stats-card--wide">
    <div class="stats-card-title">Дубли правил</div>
    <div class="stats-ok">✓ Дублей не найдено</div>
  </div>
  <% } %>

</div>

<%- include('_footer') %>
