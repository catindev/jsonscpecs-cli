<%
  var isLib      = condition.id.startsWith('library.');
  var cmpCond    = compiled.conditions && compiled.conditions.get(condition.id);
  var steps      = cmpCond ? cmpCond.steps : [];
  var whenHtml   = cmpCond ? whenTools.renderWhenTreeHtml(cmpCond.when, function(predId) {
    var pred = compiled.registry.get(predId);
    var lbl  = pred ? (pred.description || pred.id) : predId;
    return '<a class="cond-when-link" href="/rules/' + encodeURIComponent(predId) + '">' + whenTools.escapeHtml(lbl) + '</a>';
  }, { className: 'cond-when-tree' }) : '';
%>
<%- include('_header', { title: condition.description || condition.id, isLibrary: isLib, icons }) %>

<a class="back-link" href="javascript:history.back()">
  <svg viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  Назад
</a>

<div class="hero">
  <span class="hero-icon"><%- isLib ? icons['big-condition-library'] : icons['big-condition'] %></span>
  <div class="hero-body">
    <h1 class="hero-title"><%= condition.description || condition.id %></h1>
    <div class="hero-sub"><strong>Условие:</strong> <%= condition.id %></div>
  </div>
</div>

<% if (whenHtml) { %>
<div class="cond-block">
  <div class="cond-block-header">Когда выполняется условный блок</div>
  <%- whenHtml %>
</div>
<% } %>

<% if (steps.length > 0) { %>
<div class="cond-block">
  <div class="cond-block-header">Проверки:</div>
  <ul class="cond-block-list">
    <% steps.forEach(function(step) { %>
      <% if (step.kind === 'rule') {
        var a = compiled.registry.get(step.ruleId);
      %>
      <li class="cond-block-item">
        <span class="cond-block-item-icon"><%- icons['rule-list-icon'] %></span>
        <a href="/rules/<%= encodeURIComponent(step.ruleId) %>"><%= a ? (a.description || a.id) : step.ruleId %></a>
      </li>
      <% } else if (step.kind === 'condition') {
        var a = compiled.registry.get(step.conditionId);
      %>
      <li class="cond-block-item">
        <span class="cond-block-item-icon"><%- icons['condition-list-icon'] %></span>
        <a href="/conditions/<%= encodeURIComponent(step.conditionId) %>"><%= a ? (a.description || a.id) : step.conditionId %></a>
      </li>
      <% } else if (step.kind === 'pipeline') {
        var a = compiled.registry.get(step.pipelineId);
      %>
      <li class="cond-block-item">
        <span class="cond-block-item-icon"><%- icons['pipeline-list-icon'] %></span>
        <a href="/pipelines/<%= encodeURIComponent(step.pipelineId) %>"><%= a ? (a.description || a.id) : step.pipelineId %></a>
      </li>
      <% } %>
    <% }) %>
  </ul>
</div>
<% } %>

<%- include('_footer') %>
