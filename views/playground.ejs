<%- include('_header', { title: (pipeline.description || pipeline.id) + '   Тест', isLibrary: pipeline.id.startsWith('library.'), icons }) %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/codemirror.min.css">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/addon/lint/lint.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/addon/edit/matchbrackets.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/addon/edit/closebrackets.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/addon/lint/lint.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/addon/lint/json-lint.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jsonlint/1.6.0/jsonlint.min.js"></script>

<a class="back-link" href="/pipelines/<%= encodeURIComponent(pipeline.id) %>">
  <svg viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  <%= pipeline.description || pipeline.id %>
</a>

<div class="hero">
  <span class="hero-icon"><%- pipeline.id.startsWith('library.') ? icons['big-pipline-library'] : icons['big-pipline'] %></span>
  <div class="hero-body">
    <h1 class="hero-title"><%= pipeline.description || pipeline.id %></h1>
    <div class="hero-sub"><strong>Сценарий:</strong> <%= pipeline.id %></div>
  </div>
</div>

<div class="tabs">
  <a class="tab-btn tab-btn--link" href="/pipelines/<%= encodeURIComponent(pipeline.id) %>">Структура</a>
  <a class="tab-btn tab-btn--link" href="/pipelines/<%= encodeURIComponent(pipeline.id) %>/stats">Статистика</a>
  <a class="tab-btn tab-btn--link" href="/pipelines/<%= encodeURIComponent(pipeline.id) %>/doc">Документация</a>
  <button class="tab-btn tab-btn--active">Проверить</button>
</div>

<!-- Тулбар режима результата -->
<div class="pg-toolbar" id="pg-result-actions" style="display:none">
  <span id="pg-status-badge" class="pg-status-badge pg-status-badge--idle"> </span>
  <button class="pg-btn pg-btn--secondary" id="pg-back">
    <svg viewBox="0 0 16 16" fill="none" width="14" height="14"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Изменить данные
  </button>
</div>

<!-- Редактор -->
<div id="pg-editor-wrap" class="pg-panel">
  <!-- Панель над редактором: слева   инструменты, справа   запуск -->
  <div id="pg-editor-actions" class="pg-editor-toolbar">
    <div class="pg-editor-toolbar-left">
      <% if (examples && examples.length) { %>
      <div class="playground-examples">
        <span class="playground-label">Примеры:</span>
        <% examples.forEach(function(ex) { %>
        <button class="pg-example-btn" data-body="<%= encodeURIComponent(ex.body) %>"><%= ex.name %></button>
        <% }) %>
      </div>
      <% } %>
      <button class="pg-btn pg-btn--secondary" id="pg-beautify">Форматировать</button>
      <button class="pg-btn pg-btn--secondary" id="pg-copy">Копировать</button>
    </div>
    <div class="pg-editor-toolbar-right">
      <button class="pg-btn pg-btn--primary" id="pg-run">
        <svg viewBox="0 0 16 16" fill="none" width="14" height="14"><path d="M5 3l8 5-8 5V3z" fill="currentColor"/></svg>
        Выполнить проверки
      </button>
    </div>
  </div>
  <textarea id="pg-editor"></textarea>
</div>

<!-- Результат -->
<div id="pg-result-wrap" class="pg-panel" style="display:none">
  <div id="pg-result-body" class="pg-result-body"></div>
</div>

<script>
(function() {
  const PIPELINE_ID = '<%= pipeline.id %>';

  // currentDate обязателен для сценариев с датовыми проверками
  const today = new Date().toISOString().slice(0, 10);
  const DEFAULT_PAYLOAD = JSON.stringify({
    context: { pipelineId: PIPELINE_ID, currentDate: today },
    payload: {}
  }, null, 2);

  // CodeMirror
  const editor = CodeMirror.fromTextArea(document.getElementById('pg-editor'), {
    mode: { name: 'javascript', json: true },
    theme: 'jsonspecs',
    lineNumbers: true,
    matchBrackets: true,
    autoCloseBrackets: true,
    gutters: ['CodeMirror-lint-markers'],
    lint: true,
    tabSize: 2,
    indentWithTabs: false,
    lineWrapping: false,
  });
  // Восстанавливаем последний payload из localStorage
  const STORAGE_KEY = 'pg_payload_' + PIPELINE_ID;
  const STORAGE_RESULT_KEY = 'pg_result_' + PIPELINE_ID;
  const RULE_REGISTRY = <%- traceRegistry %>;
  const saved = (() => { try { return localStorage.getItem(STORAGE_KEY); } catch(e) { return null; } })();
  function withVisiblePipelineId(raw) {
    try {
      const parsed = raw ? JSON.parse(raw) : {};
      if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return DEFAULT_PAYLOAD;
      if (!parsed.context || typeof parsed.context !== 'object' || Array.isArray(parsed.context)) parsed.context = {};
      if (!parsed.context.pipelineId) parsed.context.pipelineId = PIPELINE_ID;
      if (!parsed.context.currentDate) parsed.context.currentDate = today;
      if (!Object.prototype.hasOwnProperty.call(parsed, 'payload')) parsed.payload = {};
      return JSON.stringify(parsed, null, 2);
    } catch(e) {
      return raw || DEFAULT_PAYLOAD;
    }
  }
  editor.setValue(withVisiblePipelineId(saved || DEFAULT_PAYLOAD));

  // Восстанавливаем последний результат если есть
  (function() {
    try {
      var savedResult = localStorage.getItem(STORAGE_RESULT_KEY);
      if (savedResult) { renderResult(JSON.parse(savedResult)); showResult(); }
    } catch(e) {}
  })();



  // ── Рендерер трейса ──────────────────────────────────────────────────────
  // Трейс теперь самодостаточен: description/field/operator приходят в data.
  // RULE_REGISTRY используется только как fallback для старых снепшотов.
  function renderTrace(trace) {
    var prevMs = trace.length > 0 ? new Date(trace[0].ts).getTime() : 0;
    return trace.map(function(ev) {
      var evMs = ev.ts ? new Date(ev.ts).getTime() : prevMs;
      var deltaMs = evMs - prevMs;
      prevMs = evMs;
      var msg  = ev.message || '';
      var data = ev.data || {};
      var ts   = ev.ts ? ev.ts.slice(11, 23) : '';
      var icon = '', label = '', details = [], cls = 'tev tev--meta';

      // Вспомогательная функция: строим taг-детали
      function kv(k, v) {
        if (!v && v !== 0) return '';
        return '<span class="tev-kv"><span class="tev-k">' + esc(k) + '</span><span class="tev-v">' + esc(String(v)) + '</span></span>';
      }

      if (msg === 'exec rule step') {
        var rid   = data.ruleId || '';
        var rdesc = data.description || (RULE_REGISTRY[rid] && RULE_REGISTRY[rid].description) || rid;
        var role  = data.role || (RULE_REGISTRY[rid] && RULE_REGISTRY[rid].role) || '';
        var field = data.field || (RULE_REGISTRY[rid] && RULE_REGISTRY[rid].field) || '';
        var op    = data.operator || (RULE_REGISTRY[rid] && RULE_REGISTRY[rid].operator) || '';
        var val   = data.value !== undefined ? data.value : '';
        var actual = data.actual !== undefined ? data.actual : '';
        icon  = '▸'; cls = 'tev tev--rule';
        label = (role === 'predicate' ? 'Предикат ' : 'Правило ')
              + '<a class="tev-link" href="/rules/' + encodeURIComponent(rid) + '">' + esc(rdesc) + '</a>';
        if (field) details.push(kv('поле', field));
        if (op)    details.push(kv('оператор', op));
        if (val !== '')   details.push(kv('ожидаемое значение', val));
        if (actual !== '') details.push(kv('фактическое значение', actual));

      } else if (msg === 'exec pipeline step') {
        var pid   = data.pipelineId || '';
        var pdesc = data.description || pid;
        icon = ''; cls = 'tev tev--pipeline';
        label = 'Вложенный сценарий  <a class="tev-link tev-link--pipeline" href="/pipelines/'
              + encodeURIComponent(pid) + '">' + esc(pdesc) + '</a>';

      } else if (msg === 'exec condition step') {
        var cid   = data.conditionId || '';
        var cdesc = data.description || cid;
        icon = ''; cls = 'tev tev--condition';
        label = 'Условие <a class="tev-link tev-link--condition" href="/conditions/'
              + encodeURIComponent(cid) + '">' + esc(cdesc) + '</a>';

      } else if (msg === 'exec predicate step') {
        var prid   = data.ruleId || '';
        var prdesc = data.description || (RULE_REGISTRY[prid] && RULE_REGISTRY[prid].description) || prid;
        var prfield = data.field || (RULE_REGISTRY[prid] && RULE_REGISTRY[prid].field) || '';
        var prop    = data.operator || (RULE_REGISTRY[prid] && RULE_REGISTRY[prid].operator) || '';
        icon = ''; cls = 'tev tev--meta';
        label = 'Оценка предиката <a class="tev-link" href="/rules/'
              + encodeURIComponent(prid) + '">' + esc(prdesc) + '</a>';
        if (prfield) details.push(kv('поле', prfield));
        if (prop)    details.push(kv('оператор', prop));

      } else if (msg === 'predicate UNDEFINED treated as FALSE') {
        icon = ''; cls = 'tev tev--meta';
        var urid  = data.ruleId || '';
        var urdesc = (RULE_REGISTRY[urid] && RULE_REGISTRY[urid].description) || '';
        var urfield = (RULE_REGISTRY[urid] && RULE_REGISTRY[urid].field) || '';
        label = 'Поле отсутствует в данных   условие не применялось';
        if (urdesc)  details.push(kv('предикат', urdesc));
        if (urfield) details.push(kv('поле', urfield));

      } else if (msg === 'rule result') {
        var isOk = data.status === 'OK';
        cls = 'tev tev--rule-result ' + (isOk ? 'tev--ok' : 'tev--fail');
        if (isOk) {
          label = '<span class="tev-ok">Проверка пройдена</span>';
        } else {
          label = '<span class="tev-fail">Проверка не пройдена</span>';
          if (data.level) details.push(kv('уровень', data.level));
          if (data.code)  details.push(kv('код', data.code));
        }

      } else if (msg === 'condition evaluated') {
        cls  = 'tev tev--cond-result ' + (data.result ? 'tev--cond-ok' : 'tev--cond-fail');
        label = 'Условие ' + (data.result
          ? '<span class="tev-cond-ok">выполнено</span>'
          : '<span class="tev-cond-fail">не выполнено</span>');
        details.push(kv('режим', data.whenMode || ''));

      } else if (msg === 'pipeline stopped by EXCEPTION') {
        icon = ''; cls = 'tev tev--stop';
        label = 'Сценарий остановлен исключением из правил (EXCEPTION)';

      } else if (msg === 'STOP by EXCEPTION-level rule') {
        icon = ''; cls = 'tev tev--stop';
        var sid = data.ruleId || '';
        label = 'Правило <a class="tev-link" href="/rules/'
              + encodeURIComponent(sid) + '">' + esc(sid) + '</a> не прошло проверку';

      } else if (msg === 'STOP by strict pipeline boundary') {
        icon = ''; cls = 'tev tev--stop';
        label = 'Строгий блок   остановка';
        details.push(kv('сценарий', data.pipelineId || ''));

      } else if (msg === 'wildcard expanded') {
        icon = '';
        label = 'Wildcard раскрыт';
        details.push(kv('паттерн', data.pattern || ''));
        details.push(kv('полей', data.matched || 0));

      } else if (msg === 'wildcard aggregate') {
        icon = '';
        label = 'Агрегация ' + esc(data.mode || '');
        details.push(kv('результат', String(data.result !== undefined ? data.result : '')));

      } else if (msg === 'pipeline ABORT (runtime exception)') {
        icon = ''; cls = 'tev tev--stop';
        label = 'Ошибка выполнения';
        details.push(kv('ошибка', data.error || ''));

      } else {
        label = esc(msg);
        details = Object.entries(data).map(function(e) { return kv(e[0], e[1]); });
      }

      var h = '<div class="' + cls + '">';
      h += '<span class="tev-body"><span class="tev-label">' + label + '</span>';
      if (details.length) h += '<span class="tev-details">' + details.join('') + '</span>';
      var deltaStr = (typeof deltaMs !== 'undefined' && deltaMs > 0) ? ' <span class="tev-delta">(+' + deltaMs + 'ms)</span>' : '';
      h += '</span><span class="tev-ts">' + esc(ts) + deltaStr + '</span></div>';
      return h;
    }).join('');
  }


  // Примеры
  document.querySelectorAll('.pg-example-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      editor.setValue(decodeURIComponent(btn.dataset.body));
      editor.focus();
      document.querySelectorAll('.pg-example-btn').forEach(function(b) { b.classList.remove('pg-example-btn--active'); });
      btn.classList.add('pg-example-btn--active');
    });
  });

  // Причесать
  document.getElementById('pg-copy').addEventListener('click', function() {
    const text = editor.getValue();
    navigator.clipboard.writeText(text).then(function() {
      const btn = document.getElementById('pg-copy');
      const orig = btn.textContent;
      btn.textContent = 'Скопировано';
      btn.disabled = true;
      setTimeout(function() { btn.textContent = orig; btn.disabled = false; }, 1500);
    }).catch(function() {
      alert('Не удалось скопировать');
    });
  });

  document.getElementById('pg-beautify').addEventListener('click', function() {
    try { editor.setValue(JSON.stringify(JSON.parse(editor.getValue()), null, 2)); }
    catch(e) {}
  });

  // Выполнить проверки
  document.getElementById('pg-run').addEventListener('click', run);

  // Изменить данные   вернуться к редактору
  document.getElementById('pg-back').addEventListener('click', showEditor);

  function showEditor() {
    try { localStorage.removeItem(STORAGE_RESULT_KEY); } catch(e) {}
    document.getElementById('pg-editor-wrap').style.display = '';
    document.getElementById('pg-result-wrap').style.display = 'none';
    document.getElementById('pg-editor-actions').style.display = '';
    document.getElementById('pg-result-actions').style.display = 'none';
    editor.refresh();
  }

  function showResult() {
    document.getElementById('pg-editor-wrap').style.display = 'none';
    document.getElementById('pg-result-wrap').style.display = '';
    document.getElementById('pg-editor-actions').style.display = 'none';
    document.getElementById('pg-result-actions').style.display = '';
  }

  async function run() {
    const rawPayload = editor.getValue();
    let body;
    try { body = JSON.parse(rawPayload); }
    catch(e) { alert('Невалидный JSON: ' + e.message); return; }

    const btn = document.getElementById('pg-run');
    btn.disabled = true;
    btn.textContent = 'Запрос...';

    try {
      // Сохраняем payload в localStorage
      try { localStorage.setItem(STORAGE_KEY, rawPayload); } catch(e) {}
      const t0 = performance.now();
      const resp = await fetch('/v1/debug', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const result = await resp.json();
      result.__requestMs = Math.round(performance.now() - t0);
      renderResult(result);
      try { localStorage.setItem(STORAGE_RESULT_KEY, JSON.stringify(result)); } catch(e) {}
      showResult();
    } catch(e) {
      alert('Ошибка запроса: ' + e.message);
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<svg viewBox="0 0 16 16" fill="none" width="14" height="14"><path d="M5 3l8 5-8 5V3z" fill="currentColor"/></svg> Выполнить проверки';
    }
  }

  function renderResult(result) {
    const status = result.status || (result.error ? 'ERROR' : '?');
    const badge = document.getElementById('pg-status-badge');
    badge.className = 'pg-status-badge pg-status-badge--' + (status === 'OK' ? 'ok' : status === 'EXCEPTION' ? 'exception' : 'error');
    badge.textContent = status;

    let html = '';

    // Issues / runtime status
    const issues = result.issues || [];
    const hasRuntimeError = !!(result.error || result.runtimeError || status === 'ABORT');
    const isSuccess = status === 'OK' && !hasRuntimeError && issues.length === 0;
    if (isSuccess) {
      html += '<div class="pg-section"><div class="pg-no-issues">✓ Ошибок и исключений не найдено. Данные успешно прошли проверку по сценарию проверок.</div></div>';
    } else if (hasRuntimeError) {
      const errMsg = result.message || (result.error && (result.error.message || result.error)) || result.runtimeError || 'Неизвестная ошибка выполнения';
      html += '<div class="pg-section"><div class="pg-issue pg-issue--exception">'
        + '<span class="pg-issue-level">ABORT</span>'
        + '<span class="pg-issue-code">RUNTIME_ERROR</span>'
        + '<span class="pg-issue-msg">' + esc(String(errMsg)) + '</span>'
        + '</div></div>';
    }
    if (issues.length > 0) {
      html += '<div class="pg-section"><div class="pg-section-title">Проблемы (' + issues.length + ')</div><ul class="pg-issues">';
      issues.forEach(function(iss) {
        html += '<li class="pg-issue pg-issue--' + esc((iss.level||'error').toLowerCase()) + '">'
          + '<span class="pg-issue-level">' + esc(iss.level||'') + '</span>'
          + '<span class="pg-issue-code">'  + esc(iss.code||'')  + '</span>'
          + '<span class="pg-issue-msg">'   + esc(iss.message||'') + '</span>'
          + '</li>';
      });
      html += '</ul></div>';
    }

    // Trace
    if (result.trace && result.trace.length) {
      var t1ms = new Date(result.trace[0].ts).getTime();
      var t2ms = new Date(result.trace[result.trace.length - 1].ts).getTime();
      var execMs = t2ms > t1ms ? (t2ms - t1ms) + ' мс' : '< 1 мс';
      var reqMs  = result.__requestMs !== undefined ? result.__requestMs + ' мс' : '';
      html += '<div class="pg-section">';
      html += '<div class="pg-trace-header">';
      html += '<span class="pg-trace-title">Лог операций и событий (trace)</span>';
      html += '<span class="pg-trace-meta">';
        html += '<span class="pg-trace-metric"><span class="pg-trace-metric-label">размер лога</span><span class="pg-trace-metric-val">' + result.trace.length + '</span></span>';
      html += '<span class="pg-trace-metric"><span class="pg-trace-metric-label">выполнение</span><span class="pg-trace-metric-val">' + execMs + '</span></span>';
      if (reqMs) html += '<span class="pg-trace-metric"><span class="pg-trace-metric-label">запрос</span><span class="pg-trace-metric-val">' + reqMs + '</span></span>';
      html += '</span></div>';
      html += '<div class="pg-trace-log">' + renderTrace(result.trace) + '</div>';
      html += '</div>';
    }

    document.getElementById('pg-result-body').innerHTML = html;
  }


  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
})();
</script>

<%- include('_footer') %>
